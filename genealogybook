// --- CONFIGURATION ---
const API_KEY = 'YOUR_API_KEY_HERE'; // Make sure the quote is at the end!
const SOURCE_FOLDER_ID = 'YOUR FOLDER ID'; 
const OUTPUT_DOC_ID = 'Target output doc ID'; 

function processImagesWithGemini() {
  const sourceFolder = DriveApp.getFolderById(SOURCE_FOLDER_ID);
  const files = sourceFolder.getFilesByType(MimeType.JPEG);
  var doc = DocumentApp.openById(OUTPUT_DOC_ID);
  var body = doc.getBody();

  // 1. Auto-Detect Model
  const modelName = getBestAvailableModel(API_KEY);
  if (!modelName) {
    Logger.log("CRITICAL ERROR: No Gemini models found.");
    return;
  }
  
  Logger.log(`Using Model: ${modelName}`);

  // 2. Collect and Sort Files
  const fileArray = [];
  while (files.hasNext()) {
    fileArray.push(files.next());
  }

  if (fileArray.length === 0) {
    Logger.log("No JPEG files found!");
    return;
  }

  // Sorts numerically (1, 2, 10)
  fileArray.sort((a, b) => a.getName().localeCompare(b.getName(), undefined, {numeric: true, sensitivity: 'base'}));

  // 3. Process Loop
  for (const file of fileArray) {
    const fileName = file.getName();
    Logger.log(`Processing file: ${fileName}`);

    try {
      const imageBlob = file.getBlob();
      const base64Image = Utilities.base64Encode(imageBlob.getBytes());

      const payload = {
        "contents": [{
          "parts": [
            { "text": "Transcribe the text in this image perfectly. Maintain the original spelling, punctuation, and style. Do not correct typos. If a word is hyphenated across lines, rejoin it. Format poetry as stanzas and obituaries as clear blocks. Output ONLY the transcript." },
            { "inline_data": { "mime_type": "image/jpeg", "data": base64Image }}
          ]
        }]
      };

      const url = `https://generativelanguage.googleapis.com/v1beta/${modelName}:generateContent?key=${API_KEY}`;
      const options = {
        'method': 'post',
        'contentType': 'application/json',
        'payload': JSON.stringify(payload),
        'muteHttpExceptions': true
      };

      const response = UrlFetchApp.fetch(url, options);
      const json = JSON.parse(response.getContentText());

      if (json.candidates && json.candidates[0].content) {
        const aiText = json.candidates[0].content.parts[0].text;
        
        var headerPara = body.appendParagraph("FILE: " + fileName);
        headerPara.setBold(true);
        headerPara.setFontSize(14); 

        body.appendParagraph(aiText);
        body.appendHorizontalRule(); 
        body.appendPageBreak();

        // Save progress to the Doc
        doc.saveAndClose();
        doc = DocumentApp.openById(OUTPUT_DOC_ID);
        body = doc.getBody();

        Logger.log(`SUCCESS: ${fileName}`);
      } else {
        Logger.log(`ERROR on ${fileName}: ${JSON.stringify(json)}`);
      }
    } catch (e) {
      Logger.log(`FAILED: ${fileName}. Error: ${e.message}`);
    }
    
    Utilities.sleep(2000); // Wait 2 seconds between images
  }

  Logger.log("Script Finished.");
}

function getBestAvailableModel(apiKey) {
  try {
    const url = `https://generativelanguage.googleapis.com/v1beta/models?key=${apiKey}`;
    const response = UrlFetchApp.fetch(url);
    const json = JSON.parse(response.getContentText());
    
    // Look for the newest Flash model
    const flashModels = json.models.filter(m => 
      m.name.toLowerCase().includes("flash") && 
      m.supportedGenerationMethods.includes("generateContent")
    );
    
    return flashModels.length > 0 ? flashModels[0].name : "models/gemini-1.5-flash";
  } catch (e) {
    return "models/gemini-1.5-flash"; 
  }
}
